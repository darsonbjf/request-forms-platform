# PostgreSQL
POSTGRES_USER=forms_user
POSTGRES_PASSWORD=forms_password
POSTGRES_DB=forms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://forms_user:forms_password@postgres:5432/forms?schema=forms

# Backend
PORT=3001
API_PREFIX=/forms
JWT_SECRET=change-me-before-use
ADMIN_PASSWORD=change-me-before-use
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# reCAPTCHA
SECRET_KEY=replace-with-recaptcha-secret
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# Frontend
VITE_BASE_URL=http://localhost:3001
VITE_API_PREFIX=/forms
VITE_RECAPTCHA_SITE_KEY=replace-with-recaptcha-site-key
VITE_REQUIRED_FILE_KEY_SELFIE=SELFIE
VITE_REQUIRED_FILE_KEY_AUTHORIZATION=AUTHORIZATION_DOCUMENT
VITE_REQUIRED_FILE_KEY_CERTIFICATE=CERTIFICATE

# Optional observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=request-forms-platform
